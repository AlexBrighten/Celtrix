    "db:studio": "npx drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0",
    "@clerk/express": "^1.3.0",
    "@trpc/server": "^11.1.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.0"
  }
}
