    "db:migrate": "npx drizzle-kit migrate",
    "db:studio": "npx drizzle-kit studio"
  },
  "dependencies": {
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "dotenv": "^16.5.0",
    "morgan": "^1.10.0",
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.44.0",
    "postgres": "^3.4.0",
    "@clerk/express": "^1.3.0",
    "@trpc/server": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0"
